# Copy this file to `.dev.vars` and fill in your real token for local dev.
# `.dev.vars` is gitignored — never commit real secrets.
# Get a free API token at https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=your-football-data-org-token-here
# Optional: protects POST /api/sync. If set, the endpoint requires
# `Authorization: Bearer <SYNC_KEY>`. Recommended for production.
SYNC_KEY=any-long-random-string
# Optional: the-odds-api.com key for bookmaker-odds ingestion (+EV value
# finder). Free tier is 500 requests/month. Leave as replace-me to keep the
# odds endpoints disabled locally. https://the-odds-api.com/liveapi/guides/v4/
ODDS_API_KEY=replace-me
